---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import PearlCard from '../components/PearlCard.astro';
import SourcingFlow from '../components/SourcingFlow.astro';

// 一键读取你的虚拟数据库
import pearlsData from '../data/pearls.json';

// 1. 自动提取 JSON 里所有的不重复分类
const categories = [...new Set(pearlsData.map(item => item.category))];
---

<Layout title="Miles Source | Custom Pearl Hunter & Curator">
  {/* 1. 极简奢华的 Hero 区域 */}
  <section class="py-20 text-center md:py-28">
    <!-- 🎯 调整后的现代社论风排版结构 -->
    <div class="text-center max-w-3xl mx-auto px-4">

      <h1 class="text-4xl md:text-6xl font-serif text-stone-100 tracking-wide leading-tight">
        Curating Nature's <br />
        <span class="logo-shimmer italic font-light">Beautiful Anomalies</span>
      </h1>

      <p class="text-[10px] md:text-xs uppercase tracking-[0.3em] font-mono text-stone-500 mt-5 mb-8 select-none">
        Bespoke Pearl Hunting
      </p>

      <p class="text-sm md:text-base text-stone-400 font-light leading-relaxed max-w-2xl mx-auto opacity-90">
        Every baroque pearl carries its own unique poetry. We don't sell standardized stock. 
        We scour the depths of the Zhuji market to hunt down the specific organic contours 
        and mirror luster that ignite your next jewelry sketch.
      </p>

    </div>
  </section>

  {/* 2. 展厅（Showroom）展示墙 */}
  <section id="showroom" class="scroll-mt-24">
    <div class="flex justify-center md:justify-between items-center border-b border-stone-900/80 pb-4 mb-0">
      <h2 class="text-[11px] md:text-[16px] uppercase tracking-[0.25em] text-[#E5C284] font-semibold text-center md:text-left">
        Digital Showroom
      </h2>
      <span class="hidden md:flex text-[12px] uppercase tracking-widest text-stone-500 items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500/80"></span>
        Live Sourcing Active
      </span>
    </div>

    <div class="showroom-wrapper flex flex-col gap-5">
      {categories.map((category, index) => {
        const filteredPearls = pearlsData.filter(item => item.category === category);
        
        return (
          <section class="category-section" id={`section-${index}`}>
            <div class="category-header border-b border-stone-900/40 pb-4 mb-1 text-left">
              <h2 class="category-title text-[15px] md:text-[25px] font-serif text-stone-100 tracking-wide">
                <span class="text-stone-500! mr-2 font-mono">{String(index + 1).padStart(2, '0')} /</span> 
                {category}
              </h2>
            </div>
            
            {/* 🎯 滑动视窗容器 */}
            <div class="pearl-slider-container group/slider">
              
              {/* 🎯 侧边悬浮控制按钮：在电脑端（lg:flex）悬浮在轨道左右两侧 */}
              {filteredPearls.length > 3 && (
                <>
                  <button class="js-slider-prev slider-side-btn prev-btn hidden! lg:flex">
                    <span class="text-lg">&#10094;</span>
                  </button>
                  <button class="js-slider-next slider-side-btn next-btn hidden! lg:flex">
                    <span class="text-lg">&#10095;</span>
                  </button>
                </>
              )}

              <div class="pearl-slider-track">
                {filteredPearls.map(pearl => (
                  <div class="pearl-card-wrapper">
                    <PearlCard {...pearl} />
                  </div>
                ))}
              </div>
            </div>
          </section>
        );
      })}
    </div>
  </section>

  <SourcingFlow />
</Layout>

<script>
  const slideIndexes: Record<string, number> = {};

  function showSlide(modal: HTMLElement, index: number) {
    const slides = modal.querySelectorAll<HTMLElement>('.mySlides');
    let currentIndex = index;

    if (index >= slides.length) currentIndex = 0;
    if (index < 0) currentIndex = slides.length - 1;

    slides.forEach(slide => slide.style.display = 'none');
    slides[currentIndex].style.display = 'block';

    const modalId = modal.getAttribute('id') || '';
    slideIndexes[modalId] = currentIndex;
  }

  document.addEventListener('DOMContentLoaded', () => {
    
    // DOM 传送门：将所有弹窗移动到 <body> 根部
    document.querySelectorAll('.pearl-gallery-modal').forEach(modal => {
      document.body.appendChild(modal);
    });

    // 🎯 种类层水平轨道控制逻辑
    document.querySelectorAll('.category-section').forEach(section => {
      const track = section.querySelector('.pearl-slider-track') as HTMLElement;
      const prevBtn = section.querySelector('.js-slider-prev') as HTMLButtonElement;
      const nextBtn = section.querySelector('.js-slider-next') as HTMLButtonElement;
      
      if (!track || !prevBtn || !nextBtn) return;
      
      // 动态检测滚动位置，到头自动使侧边按钮消失（利用 opacity-0）
      function updateArrows() {
        const isAtStart = track.scrollLeft <= 5;
        const isAtEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 8;
        
        if (isAtStart) {
          prevBtn.setAttribute('disabled', 'true');
        } else {
          prevBtn.removeAttribute('disabled');
        }
        
        if (isAtEnd) {
          nextBtn.setAttribute('disabled', 'true');
        } else {
          nextBtn.removeAttribute('disabled');
        }
      }
      
      // 初始化状态
      updateArrows();
      
      // 监听物理滚动事件
      track.addEventListener('scroll', updateArrows);
      
      // 精准移动“一格”的距离（卡片实际占用宽度 + 间距）
      const getScrollAmount = () => {
        const card = track.querySelector('.pearl-card-wrapper') as HTMLElement;
        if (!card) return 300;
        const style = window.getComputedStyle(track);
        const gap = parseFloat(style.gap) || 32;
        return card.offsetWidth + gap;
      };
      
      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });
      
      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
      
      window.addEventListener('resize', updateArrows);
    });

    // 弹出图集的 iPad & 手机手势滑动支持
    document.querySelectorAll('.slideshow-container').forEach(container => {
      let touchStartX = 0;
      let touchEndX = 0;
      
      container.addEventListener('touchstart', (e) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      }, { passive: true });
      
      container.addEventListener('touchend', (e) => {
        touchEndX = (e as TouchEvent).changedTouches[0].screenX;
        handleSwipe(container as HTMLElement);
      }, { passive: true });
      
      function handleSwipe(el: HTMLElement) {
        const swipeThreshold = 40;
        const modal = el.closest('.pearl-gallery-modal') as HTMLElement;
        if (!modal) return;
        
        const modalId = modal.getAttribute('id') || '';
        const currentIndex = slideIndexes[modalId] || 0;
        
        const diffX = touchStartX - touchEndX;
        
        if (Math.abs(diffX) > swipeThreshold) {
          if (diffX > 0) {
            showSlide(modal, currentIndex + 1);
          } else {
            showSlide(modal, currentIndex - 1);
          }
        }
      }
    });

    // 点击卡片打开 Modal
    document.querySelectorAll('.pearl-item-container').forEach(container => {
      const id = container.getAttribute('data-pearl-id');
      const trigger = container.querySelector('.js-card-trigger');
      const modal = document.getElementById(`${id}-modal`);

      if (trigger && modal) {
        trigger.addEventListener('click', () => {
          modal.style.display = 'block';
          showSlide(modal, 0);
          document.body.style.overflow = 'hidden';
        });
      }
    });

    // 点击关闭按钮
    document.querySelectorAll('.js-close-modal').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const modal = (e.target as HTMLElement).closest('.pearl-gallery-modal') as HTMLElement;
        if (modal) {
          modal.style.display = 'none';
          document.body.style.overflow = '';
        }
      });
    });

    // 切换上一张
    document.querySelectorAll('.js-prev').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const modal = (e.target as HTMLElement).closest('.pearl-gallery-modal') as HTMLElement;
        const modalId = modal.getAttribute('id') || '';
        const currentIndex = slideIndexes[modalId] || 0;
        showSlide(modal, currentIndex - 1);
      });
    });

    // 切换下一张
    document.querySelectorAll('.js-next').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const modal = (e.target as HTMLElement).closest('.pearl-gallery-modal') as HTMLElement;
        const modalId = modal.getAttribute('id') || '';
        const currentIndex = slideIndexes[modalId] || 0;
        showSlide(modal, currentIndex + 1);
      });
    });

    // 点击遮罩层空白处关闭
    window.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('pearl-gallery-modal')) {
        target.style.display = 'none';
        document.body.style.overflow = '';
      }
    });
  });
</script>