---
// src/components/PearlCard.astro
interface Props {
  id: string;
  title: string;
  tags: string[];
  teaser: string; // 列表页的一句话简述
  images: string[];
  specs?: Record<string, string>; // 左侧 1/3 的硬核规格参数
  inspiration?: string; // 右侧 2/3 的灵魂灵感文案
}

const { id, title, teaser, images, specs, inspiration } = Astro.props;

const instagramUsername = "miles_source";
const dmLink = `https://ig.me/m/${instagramUsername}`;
---

<!-- 1. 外部列表卡片（去掉了 overflow-hidden 和底栏按钮） -->
<div 
  class="pearl-item-container group relative transition-all duration-500 h-full" 
  data-pearl-id={id}
>
  <!-- 卡片主视图 -->
  <div class="pearl-card-view js-card-trigger cursor-pointer bg-[#121212] border border-stone-900/60 rounded-xl p-6 hover:border-stone-800 transition-all duration-500 flex flex-col justify-between h-full">
    
    <!-- 叠放图集区域 -->
    <div class="relative w-full aspect-[4/5] bg-transparent mb-6 p-3">
      <!-- 底层照片 2 -->
      {images[2] && (
        <div class="absolute inset-3 rounded-lg overflow-hidden border border-stone-800/30 bg-stone-950 transform -rotate-3 -translate-y-2 -translate-x-1.5 opacity-30 transition-all duration-500 group-hover:-rotate-6 group-hover:-translate-y-4 group-hover:-translate-x-3.5 group-hover:opacity-50">
          <img src={images[2]} alt="" class="w-full h-full object-cover blur-[0.8px]" />
        </div>
      )}

      <!-- 底层照片 1 -->
      {images[1] && (
        <div class="absolute inset-3 rounded-lg overflow-hidden border border-stone-800/40 bg-stone-950 transform rotate-2 -translate-y-1 translate-x-1.5 opacity-60 transition-all duration-500 group-hover:rotate-4 group-hover:-translate-y-2.5 group-hover:translate-x-3.5 group-hover:opacity-80">
          <img src={images[1]} alt="" class="w-full h-full object-cover blur-[0.3px]" />
        </div>
      )}

      <!-- 顶层主图（去掉了左上角悬浮的 Extreme 标签） -->
      <div class="absolute inset-3 rounded-lg overflow-hidden border border-stone-900/80 bg-stone-950 shadow-2xl transition-all duration-500 group-hover:scale-[1.01] z-10">
        <img 
          src={images[0]} 
          alt={title} 
          class="w-full h-full object-cover" 
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-50"></div>
      </div>
    </div>

    <!-- 列表文字区域：只留纯粹的一句话 Teaser 介绍 -->
    <div class="text-left mt-auto">
      <h3 class="text-base md:text-lg font-serif text-stone-100 tracking-wide mb-2 group-hover:text-stone-300 transition-colors">
        {title}
      </h3>
      <p class="text-xs text-stone-400 font-light leading-relaxed">
        {teaser}
      </p>
    </div>
  </div>

  <!-- 2. 奢华大图弹窗（去掉了生硬的烟雾层，保持大图全屏展示） -->
  <div class="pearl-gallery-modal hidden fixed inset-0 z-[9999] bg-black/95" id={`${id}-modal`}>
    
    <!-- 关闭按钮 -->
    <span class="close-modal js-close-modal absolute top-6 right-8 z-50 !text-white/20 hover:!text-white/90 text-5xl md:text-6xl font-extralight cursor-pointer p-6 transition-colors select-none">&times;</span>

    <div class="relative h-full w-full overflow-hidden flex flex-col justify-between">
      
      <!-- 【上半部分图集区域】 -->
      <div class="w-full h-full flex items-center justify-center p-4 pb-[42vh] md:pb-[35vh] relative z-10">
        
        <!-- 左右切换自适应中点箭头 -->
        <a 
          class="prev js-prev hidden lg:flex absolute top-1/2 -translate-y-1/2 !text-white/15 hover:!text-white/95 text-6xl xl:text-7xl font-light cursor-pointer select-none !p-12 transition-all z-30 items-center justify-center"
          style="left: calc(25vw - 192px);"
        >
          &#10094;
        </a>
        
        <a 
          class="next js-next hidden lg:flex absolute top-1/2 -translate-y-1/2 !text-white/15 hover:!text-white/95 text-6xl xl:text-7xl font-light cursor-pointer select-none !p-12 transition-all z-30 items-center justify-center"
          style="right: calc(25vw - 192px);"
        >
          &#10095;
        </a>

        <!-- 幻灯片容器 -->
        <div class="slideshow-container w-full max-w-3xl relative">
          {images.map((imgUrl, index) => (
            <div class="mySlides fade hidden">
              <img 
                src={imgUrl} 
                alt={`${title} - Angle ${index + 1}`} 
                class="w-full max-h-[48vh] md:max-h-[55vh] object-contain rounded-lg mx-auto select-none pointer-events-none" 
              />
            </div>
          ))}
        </div>
      </div>

      <!-- 【下半部分 1/3 磨砂双栏面板】 -->
      <div 
        class="absolute bottom-0 left-0 w-full h-[38vh] md:h-[32vh] z-20 bg-[#0B0B0B]/90 backdrop-blur-2xl px-6 py-10 md:px-16 md:py-12 overflow-y-auto"
      >
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start max-w-6xl mx-auto h-full">
          
          <!-- 【左边 1/3 区域】 -->
          <div class="md:col-span-4 space-y-4 text-left">
            <h2 class="text-xl md:text-2xl font-serif text-stone-100 tracking-wide leading-tight">{title}</h2>
            
            {specs && (
              <div class="space-y-1.5 text-[10px] md:text-xs">
                {Object.entries(specs).map(([key, value]) => (
                  <div class="flex justify-between border-b border-stone-900/40 pb-1">
                    <span class="text-stone-500 uppercase tracking-wider">{key}</span>
                    <span class="text-stone-300 font-medium">{value}</span>
                  </div>
                ))}
              </div>
            )}

            <div class="pt-2">
              <a 
                href={dmLink} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-[10px] uppercase tracking-[0.2em] text-amber-500/80 hover:text-amber-400 transition-colors inline-flex items-center gap-1.5 border-b border-amber-500/20 hover:border-amber-500/60 pb-0.5"
              >
                Inquire Specimen <span class="text-xs">→</span>
              </a>
            </div>
          </div>

          <!-- 【右边 2/3 区域】 -->
          <div class="md:col-span-8 text-left h-full flex flex-col justify-center">
            <div class="space-y-4">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-stone-700"></span>
                <span class="text-[9px] uppercase tracking-[0.25em] text-stone-500 font-bold">Curator's Voice</span>
              </div>
              
              {inspiration && (
                <p class="text-xs md:text-sm text-stone-300 font-light leading-relaxed italic border-l border-stone-900/80 pl-6 py-1">
                  "{inspiration}"
                </p>
              )}
            </div>
          </div>

        </div>

      </div>

    </div>
  </div>
</div>