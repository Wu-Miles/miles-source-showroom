---
// src/components/SourcingFlow.astro

import steps_1 from "../assets/flow-1.png";
import steps_2 from "../assets/flow-2.png";
import steps_3 from "../assets/flow-3.png";

const flowSteps = [
  {
    num: "01",
    title: "Share Your Muse",
    desc: "Share your design sketches, mood boards, or reference photos to ignite the private hunt.",
    img: steps_1 
  },
  {
    num: "02",
    title: "The Live Hunt",
    desc: "I head directly into the source market to live-scout and curate the absolute best options for you.",
    img: steps_2  
  },
  {
    num: "03",
    title: "Match & Deliver",
    desc: "Review high-definition details, approve your bespoke layout, and receive pristine secure delivery.",
    img: steps_3 
  }
];


---

<section id="sourcing-flow" class="py-16 border-t border-stone-900/60">
  {/* 区域标题 */}
  <div class="text-center max-w-2xl mx-auto mb-16">
    <h2 class="text-3xl font-serif text-stone-100 tracking-wide mt-3 mb-4">
      Your Private Pearl Hunter
    </h2>
    <p class="text-sm text-stone-400 font-light leading-relaxed">
      No catalogs. No mass-produced stock. Just a bespoke sourcing experience designed to feed your creative intuition, direct from the source.
    </p>
  </div>

    <!-- 🎯 3列 4:5 顶级画廊矩阵 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {flowSteps.map((step) => (
        <div class="group flex flex-col">
          
          <!-- 🖼️ 4:5 黄金比例图片容器（采纳了最新的规范写法 aspect-4/5） -->
          <div class="w-full aspect-4/5 rounded-2xl overflow-hidden border border-stone-900 bg-stone-950/40 mb-6 relative transition-all duration-500 group-hover:border-stone-800/80">
            
            <!-- 流程插图 -->
            <img 
              src={step.img.src} 
              alt={step.title}
              class="w-full h-full object-cover opacity-85 group-hover:opacity-100 transition-opacity duration-500"
            />
            
            <!-- 右上角优雅的序号悬浮标签 -->
            <span class="absolute top-5 right-5 text-[10px] font-mono tracking-widest text-stone-500 bg-[#0B0B0B]/85 px-2 py-1 rounded backdrop-blur-sm border border-stone-900/50">
              {step.num}
            </span>
          </div>

          <!-- 下方精细排版文字 -->
          <h3 class="text-lg font-serif text-stone-200 mb-2 tracking-wide">
            {step.title}
          </h3>
          <p class="text-sm text-stone-400 font-light leading-relaxed">
            {step.desc}
          </p>
          
        </div>
      ))}
    </div>

  {/* 底部行动召唤 (Call to Action) */}
  <div class="mt-16 text-center">
    <div class="inline-flex flex-col items-center p-8 bg-linear-to-b from-[#161616] to-[#0D0D0D] border border-stone-900 rounded-2xl max-w-xl mx-auto">
      <h4 class="text-md font-serif text-stone-200 tracking-wider mb-2">Ready to find your next muse?</h4>
      <p class="text-xs text-stone-500 mb-6 font-light">Tell me what shape, luster, or weird anomaly you are searching for today.</p>
      <!-- 🎯 纯正复刻：换成和 Process 一样的深色内敛底色，让原本的外壳高亮瞬间亮起 -->
      <button id="start-sourcing-btn" class="relative bg-stone-950/60 text-[#E5C284] border border-stone-800/80 backdrop-blur-xs px-10 py-4 rounded font-serif tracking-widest text-sm uppercase transition-all duration-300">
        
        <!-- 保持你原汁原味的代码不动 -->
        <div class="absolute inset-0 rounded border border-[#E5C284]/40 shadow-[0_0_15px_rgba(229,194,132,0.3)] animate-pulse pointer-events-none"></div>

        <span class="relative z-10">
          START A SOURCING REQUEST
        </span>
      </button>
    </div>
  </div>
</section>