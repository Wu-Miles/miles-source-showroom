---
// src/components/SourcingFlow.astro

const steps = [
  {
    num: "01",
    title: "Share Your Muse",
    description: "Send me your design sketch, a reference photo of a pearl you love, or simply describe the vibe you are going for."
  },
  {
    num: "02",
    title: "The Hunt Begins",
    description: "With zero upfront deposit required, I head into the heart of the Zhuji pearl market to scour the hidden gems for you."
  },
  {
    num: "03",
    title: "Live Sourcing",
    description: "I'll send you high-definition, unfiltered videos and photos of the best matches directly from the market stalls."
  },
  {
    num: "04",
    title: "Select & Match",
    description: "You pick the exact pearls that spark your inspiration. If none of them hit the spot, we keep looking or part as friends."
  },
  {
    num: "05",
    title: "Secure Checkout",
    description: "No high minimum order quantities (MOQ). Pay safely and securely via internationally trusted payment platforms."
  },
  {
    num: "06",
    title: "Express Delivery",
    description: "Your handpicked pearls are carefully packed and shipped directly to your studio, ready to be crafted into art."
  }
];
---

<section class="py-16 border-t border-stone-900/60 mt-16">
  {/* 区域标题 */}
  <div class="text-center max-w-2xl mx-auto mb-16">
    <span class="text-xs uppercase tracking-[0.3em] text-stone-500">How It Works</span>
    <h2 class="text-3xl font-serif text-stone-100 tracking-wide mt-3 mb-4">
      Your Private Pearl Hunter
    </h2>
    <p class="text-sm text-stone-400 font-light leading-relaxed">
      No catalogs. No mass-produced stock. Just a bespoke sourcing experience designed to feed your creative intuition, direct from the source.
    </p>
  </div>

  {/* 6 步流程网格 */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative">
    {
      steps.map((step, index) => (
        <div class="relative bg-[#121212]/50 border border-stone-900/40 p-8 rounded-xl hover:border-stone-800/80 transition-all duration-300 group">
          {/* 步骤编号 - 使用大字淡化效果，营造高级感 */}
          <div class="text-4xl font-serif text-stone-800 group-hover:text-stone-700 transition-colors duration-300 mb-6 font-semibold tracking-wider">
            {step.num}
          </div>
          
          <h3 class="text-lg font-serif text-stone-200 tracking-wide mb-3">
            {step.title}
          </h3>
          
          <p class="text-xs text-stone-400 font-light leading-relaxed">
            {step.description}
          </p>

          {/* 装饰性连接线（仅在桌面端显示，连接各步骤） */}
          {index < 5 && (
            <div class="hidden lg:block absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-[1px] bg-stone-900/40 z-0 pointer-events-none group-hover:bg-stone-800/60 transition-colors" />
          )}
        </div>
      ))
    }
  </div>

  {/* 底部行动召唤 (Call to Action) */}
  <div class="mt-16 text-center">
    <div class="inline-flex flex-col items-center p-8 bg-gradient-to-b from-[#161616] to-[#0D0D0D] border border-stone-900 rounded-2xl max-w-xl mx-auto">
      <h4 class="text-md font-serif text-stone-200 tracking-wider mb-2">Ready to find your next muse?</h4>
      <p class="text-xs text-stone-500 mb-6 font-light">Tell me what shape, luster, or weird anomaly you are searching for today.</p>
      <a 
        href="https://ig.me/m/miles_source" 
        target="_blank" 
        rel="noopener noreferrer"
        class="px-8 py-3 bg-stone-200 hover:bg-white text-black text-xs uppercase tracking-[0.2em] font-semibold rounded-md transition-all duration-300 shadow-lg shadow-black/40"
      >
        Start a Sourcing Request
      </a>
    </div>
  </div>
</section>